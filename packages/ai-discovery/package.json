{
  "name": "ai-discovery",
  "version": "0.1.0-preview.0",
  "type": "module",
  "description": "CLI tools for validating, explaining, and drafting ai-catalog.json discovery assets.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sidman2/assetmason-agent-tools.git"
  },
  "bugs": {
    "url": "https://github.com/sidman2/assetmason-agent-tools/issues"
  },
  "homepage": "https://github.com/sidman2/assetmason-agent-tools#readme",
  "keywords": ["ard", "ai-catalog", "agent-operability", "agent-discovery", "cli", "mcp", "npm", "npx", "typescript"],
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "ai-discovery": "bin/ai-discovery.js"
  },
  "files": ["dist", "bin", "README.md", "LICENSE"],
  "dependencies": {
    "ard-kit": "0.1.0-preview.0"
  },
  "scripts": {
    "build": "tsc --module NodeNext --moduleResolution NodeNext --target ES2022 --strict --esModuleInterop --skipLibCheck --resolveJsonModule --declaration --outDir dist --rootDir src src/index.ts src/main.ts",
    "test": "vitest run",
    "pack:dry-run": "npm pack --dry-run"
  }
}
