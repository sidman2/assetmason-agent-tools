{
  "name": "assetmason-agent-tools",
  "private": true,
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sidman2/assetmason-agent-tools.git"
  },
  "bugs": {
    "url": "https://github.com/sidman2/assetmason-agent-tools/issues"
  },
  "homepage": "https://github.com/sidman2/assetmason-agent-tools#readme",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build -w ard-kit && npm run build -w ard-cli && npm run build -w ai-discovery && npm run build -w agent-resource-plan && npm run build -w assetmason-cli",
    "lint": "npm run typecheck",
    "typecheck": "node ./node_modules/typescript/bin/tsc -p tsconfig.json --noEmit",
    "test": "npm run build && vitest run",
    "pack:dry-run": "npm run pack:dry-run -ws --if-present",
    "names:check": "node scripts/names-check.mjs"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
