{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "baseUrl": ".",
    "paths": {
      "ard-kit": ["packages/ard-kit/src/index.ts"]
    },
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["node", "vitest/globals"]
  },
  "include": ["packages/**/*.ts", "scripts/**/*.mjs", "fixtures/**/*.json"],
  "exclude": ["**/dist/**", "**/node_modules/**"]
}
